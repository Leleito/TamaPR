{
  "name": "tamapr",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/sanity.test.ts tests/api-contact.test.ts tests/api-newsletter.test.ts",
    "test:build": "vitest run tests/build.test.ts",
    "test:docker": "docker compose -f docker-compose.test.yml up --build --abort-on-container-exit test",
    "test:docker:unit": "docker compose -f docker-compose.test.yml up --build --abort-on-container-exit test-unit",
    "test:docker:build": "docker compose -f docker-compose.test.yml up --build --abort-on-container-exit test-build"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/vercel": "^9.0.4",
    "@sanity/client": "^7.16.0",
    "@sanity/image-url": "^2.0.3",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^5.17.1",
    "groq": "^5.13.0",
    "resend": "^6.9.3",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "happy-dom": "^20.8.3",
    "vitest": "^4.0.18"
  }
}
