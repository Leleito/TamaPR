---
import BaseLayout from '../layouts/BaseLayout.astro';
import MagneticButton from '../components/MagneticButton.astro';

const audiences = [
  {
    id: 'individuals',
    title: 'For Individuals & Leaders',
    intro: 'You are your brand. Your voice is your currency. Whether you\'re a founder, executive, or creative, how you communicate shapes how you\'re remembered.',
    services: [
      { name: 'Personal Brand Strategy & Voice Discovery', desc: 'We uncover the authentic core of who you are\u2014and translate it into messaging that feels unmistakably you.', pillar: 'Pillar 1: Personal Branding & Voice' },
      { name: 'Executive Communication Coaching', desc: 'One-on-one sessions to sharpen your speaking, writing, and presence\u2014internally with your team and externally with your audience.', pillar: 'Pillar 2: Communication & PR Education' },
      { name: 'Thought Leadership Content Strategy', desc: 'From LinkedIn posts to speaking engagements, we build a content ecosystem that positions you as a trusted voice in your space.', pillar: 'Pillar 1 & Pillar 2' },
      { name: 'Public Speaking & Presentation Storytelling', desc: 'Craft speeches and presentations that don\'t just inform\u2014they move people.', pillar: 'Pillar 2 & Pillar 5' },
    ],
  },
  {
    id: 'organizations',
    title: 'For Organizations & Brands',
    intro: 'Your organization has a story. But more importantly, it has people\u2014teams, communities, stakeholders\u2014who need to hear it clearly and believe it deeply.',
    services: [
      { name: 'Strategic Narrative Development', desc: 'We help you articulate your core story\u2014the one that aligns your team, attracts your audience, and guides every communication choice.', pillar: 'Pillar 1 & Pillar 4' },
      { name: 'Ethical Storytelling & Advocacy Communications', desc: 'For organizations handling sensitive narratives\u2014whether community stories, survivor voices, or social justice campaigns\u2014we ensure every story is told with dignity, context, and consent.', pillar: 'Pillar 3: Advocacy & Ethical Storytelling' },
      { name: 'Internal Communication & Organizational Alignment', desc: 'Before the world hears your story, your team must live it. We help break silos, align departments, and build internal messaging that turns staff into culture-bearers.', pillar: 'Pillar 4: Corporate & Professional Communication' },
      { name: 'Corporate Messaging & Sustainability Reporting', desc: 'We craft sustainability narratives that reflect real practice\u2014not greenwashing\u2014and corporate communications that build trust through honesty.', pillar: 'Pillar 4' },
      { name: 'Media Relations & Impact Story Placement', desc: 'When your story is ready, we help place it where it matters\u2014with journalists, partners, and platforms that align with your mission.', pillar: 'Pillar 3 & Pillar 4' },
      { name: 'Crisis Preparedness & Communication', desc: 'Not just a crisis plan\u2014but the internal protocols and team alignment that determine whether a crisis fractures or strengthens trust.', pillar: 'Pillar 4' },
    ],
  },
  {
    id: 'hospitality',
    title: 'For Hospitality Brands',
    intro: 'Hospitality is story told through experience. Every touchpoint\u2014from front desk to housekeeping\u2014shapes what guests remember.',
    services: [
      { name: 'Guest Experience & Staff Storytelling Training', desc: 'We train your team to move beyond service into genuine connection\u2014turning staff into storytellers who reflect your brand\'s culture and community.', pillar: 'Pillar 5 & Pillar 2' },
      { name: 'Interdepartmental Communication Frameworks', desc: 'When departments don\'t talk, the guest feels it. We build systems that align front desk, housekeeping, F&B, and management around one seamless guest journey.', pillar: 'Pillar 4 (internal-first)' },
      { name: 'Cultural Narrative Strategy', desc: 'We help you weave local culture, community, and place into your brand story\u2014so guests don\'t just visit, they connect.', pillar: 'Pillar 5' },
      { name: 'Brand Voice & Messaging for Hospitality', desc: 'From website copy to guest communications, we ensure your brand voice is consistent, warm, and unmistakably yours.', pillar: 'Pillar 1 & Pillar 5' },
    ],
  },
  {
    id: 'nonprofits',
    title: 'For Non-Profits & Social Enterprises',
    intro: 'Your work changes lives. Your communication should honor that.',
    services: [
      { name: 'Impact Story Documentation', desc: 'We help you capture and share your impact in ways that serve both advocacy and fundraising\u2014without extracting from the communities you serve.', pillar: 'Pillar 3' },
      { name: 'Ethical Storytelling Protocols', desc: 'We build frameworks that ensure every community story is told with consent, dignity, and care\u2014transforming storytelling from extraction into partnership.', pillar: 'Pillar 3' },
      { name: 'Communications Training for Teams', desc: 'We equip your team with the skills to tell your story powerfully and consistently\u2014internally to stakeholders, externally to donors and partners.', pillar: 'Pillar 2' },
      { name: 'Donor & Partner Communications', desc: 'Craft narratives that build trust with funders\u2014not through performance, but through honest, compelling storytelling.', pillar: 'Pillar 3 & Pillar 4' },
    ],
  },
];

---

<BaseLayout title="Services" description="Strategic communications for purpose-driven individuals, leaders, and organizations.">

  <section class="pt-32 pb-16 bg-warm-white">
    <div class="max-w-[1200px] mx-auto px-6 md:px-16">
      <p class="text-[11px] font-semibold tracking-[2.5px] uppercase text-terracotta mb-5 reveal">Services</p>
      <h1 class="font-serif text-[42px] lg:text-[56px] text-navy leading-[1.1] max-w-[700px] reveal">
        Strategic communications for purpose-driven voices.
      </h1>
    </div>
  </section>

  {audiences.map((audience, idx) => (
    <section class={`py-20 ${idx % 2 === 0 ? 'bg-warm-white' : 'bg-off-white'}`} id={audience.id}>
      <div class="max-w-[1200px] mx-auto px-6 md:px-16">
        <div class="mb-12 reveal">
          <h2 class="font-serif text-[30px] text-navy mb-4">{audience.title}</h2>
          <p class="text-[16px] text-text-muted max-w-[600px]">{audience.intro}</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {audience.services.map((svc, i) => (
            <div class={`group relative bg-warm-white border border-navy/[0.06] rounded-xl p-7 transition-all duration-500 hover:shadow-md hover:-translate-y-0.5 reveal reveal-delay-${Math.min(i + 1, 5)}`}>
              <div class="absolute left-0 top-7 bottom-7 w-[3px] bg-terracotta/0 rounded-full transition-all duration-500 group-hover:bg-terracotta"></div>
              <h3 class="font-serif text-[18px] text-navy mb-2 pl-4">{svc.name}</h3>
              <p class="text-[14px] leading-relaxed text-text-muted pl-4 mb-2">{svc.desc}</p>
              <p class="text-[11px] text-text-soft pl-4">Rooted in {svc.pillar}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Investment -->
  <section class="py-20 bg-cream">
    <div class="max-w-[800px] mx-auto px-6 md:px-16">
      <div class="text-center mb-12 reveal">
        <p class="text-[11px] font-semibold tracking-[2px] uppercase text-terracotta mb-5">Investment</p>
        <h2 class="font-serif text-[32px] text-navy">Every engagement is custom-built.</h2>
        <p class="text-[15px] text-text-muted mt-3">Here's a sense of where conversations start:</p>
      </div>

      <div class="space-y-6">
        <!-- 1. Situational Analysis -->
        <div class="bg-warm-white border border-navy/[0.06] rounded-xl p-7 reveal">
          <div class="flex justify-between items-start mb-3">
            <div>
              <span class="text-[11px] font-semibold tracking-[1.5px] uppercase text-terracotta/60">01</span>
              <h3 class="font-serif text-[20px] text-navy mt-1">Situational Analysis & Communication Audit</h3>
            </div>
            <span class="font-serif text-[16px] text-terracotta whitespace-nowrap ml-4 mt-2">From KES 80,000</span>
          </div>
          <p class="text-[14px] text-text-muted mb-1 font-medium">A 2&ndash;4 week immersive assessment</p>
          <p class="text-[14px] leading-relaxed text-text-muted mb-4">
            A deep, structured evaluation of how your brand is currently experienced, across communication, service, and perception. It goes beyond messaging to examine alignment between what is said, what is delivered, and what is felt.
          </p>
          <div class="mb-4">
            <p class="text-[13px] font-medium text-navy mb-2">Includes:</p>
            <ul class="grid grid-cols-1 md:grid-cols-2 gap-1.5 text-[13px] text-text-muted">
              <li class="flex gap-2"><span class="text-terracotta">&#9679;</span> Internal communication review</li>
              <li class="flex gap-2"><span class="text-terracotta">&#9679;</span> Guest experience observation</li>
              <li class="flex gap-2"><span class="text-terracotta">&#9679;</span> Stakeholder engagement</li>
              <li class="flex gap-2"><span class="text-terracotta">&#9679;</span> Brand and messaging alignment</li>
              <li class="flex gap-2"><span class="text-terracotta">&#9679;</span> Digital presence assessment</li>
            </ul>
          </div>
          <div class="mb-4">
            <p class="text-[13px] font-medium text-navy mb-2">Frameworks applied:</p>
            <ul class="flex flex-wrap gap-2 text-[12px]">
              <li class="px-3 py-1 rounded-full bg-cream text-text-muted">SWOT Analysis</li>
              <li class="px-3 py-1 rounded-full bg-cream text-text-muted">Service experience mapping</li>
              <li class="px-3 py-1 rounded-full bg-cream text-text-muted">Communication flow assessment</li>
            </ul>
          </div>
          <div class="flex flex-wrap gap-x-6 gap-y-1 text-[12px] text-text-soft border-t border-navy/[0.06] pt-3">
            <span><strong class="text-navy">Where:</strong> On-site at your property</span>
            <span><strong class="text-navy">Timeline:</strong> 2&ndash;4 weeks</span>
          </div>
          <p class="text-[11px] text-text-soft mt-2 italic">
            Exact scope defined after discovery; travel/accommodation covered by client if outside Nairobi.
          </p>
        </div>

        <!-- 2. Strategic Recommendations -->
        <div class="bg-warm-white border border-navy/[0.06] rounded-xl p-7 reveal reveal-delay-2">
          <div class="flex justify-between items-start mb-3">
            <div>
              <span class="text-[11px] font-semibold tracking-[1.5px] uppercase text-terracotta/60">02</span>
              <h3 class="font-serif text-[20px] text-navy mt-1">Strategic Recommendations</h3>
            </div>
            <span class="font-serif text-[16px] text-terracotta whitespace-nowrap ml-4 mt-2">Priced on scope</span>
          </div>
          <p class="text-[14px] text-text-muted mb-1 font-medium">A structured report and advisory session</p>
          <p class="text-[14px] leading-relaxed text-text-muted mb-4">
            Following the analysis, you receive clear, actionable direction based on insights gathered.
          </p>
          <div>
            <p class="text-[13px] font-medium text-navy mb-2">This includes:</p>
            <ul class="space-y-1.5 text-[13px] text-text-muted">
              <li class="flex gap-2"><span class="text-terracotta">&#9679;</span> Key findings and patterns</li>
              <li class="flex gap-2"><span class="text-terracotta">&#9679;</span> Communication gaps and risks</li>
              <li class="flex gap-2"><span class="text-terracotta">&#9679;</span> Service culture observations</li>
              <li class="flex gap-2"><span class="text-terracotta">&#9679;</span> Strategic recommendations</li>
            </ul>
          </div>
        </div>

        <!-- 3. Advisory & Implementation -->
        <div class="bg-warm-white border border-navy/[0.06] rounded-xl p-7 reveal reveal-delay-3">
          <div class="flex justify-between items-start mb-3">
            <div>
              <span class="text-[11px] font-semibold tracking-[1.5px] uppercase text-terracotta/60">03</span>
              <h3 class="font-serif text-[20px] text-navy mt-1">Advisory & Implementation Support</h3>
            </div>
            <span class="font-serif text-[16px] text-terracotta whitespace-nowrap ml-4 mt-2">From KES 120,000/mo</span>
          </div>
          <p class="text-[14px] text-text-muted mb-1 font-medium">Ongoing or on-site support</p>
          <p class="text-[14px] leading-relaxed text-text-muted mb-4">
            For brands that require continued guidance, Tama PR offers hands-on advisory to support alignment and execution.
          </p>
          <div>
            <p class="text-[13px] font-medium text-navy mb-2">This may include:</p>
            <ul class="space-y-1.5 text-[13px] text-text-muted">
              <li class="flex gap-2"><span class="text-terracotta">&#9679;</span> On-site presence (for training, alignment, or crisis support)</li>
              <li class="flex gap-2"><span class="text-terracotta">&#9679;</span> Team workshops (guest experience, ethical storytelling, interdepartmental communication)</li>
              <li class="flex gap-2"><span class="text-terracotta">&#9679;</span> Communication guidance (internal protocols, brand voice, crisis preparedness)</li>
            </ul>
          </div>
          <p class="text-[11px] text-text-soft mt-4 italic">
            On-site engagements: transport, accommodation, and meals covered by the client.
          </p>
        </div>
      </div>

      <!-- Note -->
      <div class="mt-8 text-center reveal">
        <p class="text-[13px] text-text-soft">
          Final scope and investment are defined after an initial discovery conversation.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-navy text-center">
    <div class="max-w-[600px] mx-auto px-6 md:px-16 reveal">
      <h2 class="font-serif text-[32px] text-white mb-4">Ready to tell your story?</h2>
      <p class="text-[16px] text-white/40 mb-8">The first step is a conversation. No pressure. Just listening.</p>
      <MagneticButton href="/contact" variant="primary">Schedule a Discovery Call</MagneticButton>
    </div>
  </section>

</BaseLayout>
