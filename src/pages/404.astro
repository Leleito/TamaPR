---
import BaseLayout from '../layouts/BaseLayout.astro';
import logoTree from '../assets/images/logo-tree.jpg';
---

<BaseLayout title="Page Not Found">
  <section class="min-h-[80vh] flex items-center justify-center bg-navy">
    <div class="text-center px-8">
      <img src={logoTree.src} alt="" class="w-16 h-16 rounded-full mx-auto mb-8 opacity-40" />
      <h1 class="font-serif text-[48px] text-white mb-4">404</h1>
      <p class="text-[16px] text-white/40 mb-8 max-w-[400px] mx-auto">
        This page doesn't exist — but your story still does. Let's find the right path.
      </p>
      <a href="/" class="inline-block bg-terracotta text-white text-[14px] font-medium px-8 py-3.5 rounded-md no-underline hover:bg-terracotta-hover transition-colors duration-300">
        Return Home
      </a>
    </div>
  </section>
</BaseLayout>
