---
import BlogLayout from '../../layouts/BlogLayout.astro';
import MagneticButton from '../../components/MagneticButton.astro';
import { client, urlFor } from '../../lib/sanity';
import { toHTML } from '@portabletext/to-html';

export async function getStaticPaths() {
  const posts = await client.fetch(
    `*[_type == "post"] {
      "slug": slug.current,
      title,
      excerpt,
      "category": pillar->title,
      "categoryClass": pillar->categoryClass,
      publishedAt,
      body,
      pullQuote,
      mainImage
    }`
  );

  return posts.map((post: any) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

// Estimate read time from body blocks
const wordCount = post.body
  ? post.body
      .filter((b: any) => b._type === 'block')
      .map((b: any) => b.children?.map((c: any) => c.text).join('') || '')
      .join(' ')
      .split(/\s+/).length
  : 0;
const readTime = `${Math.max(1, Math.ceil(wordCount / 200))} min`;

// Render portable text to HTML
const bodyHtml = post.body
  ? toHTML(post.body, {
      components: {
        types: {
          image: ({ value }: any) => {
            const imgUrl = urlFor(value).width(800).auto('format').url();
            const alt = value.alt || '';
            const caption = value.caption || '';
            return `<figure>
              <img src="${imgUrl}" alt="${alt}" loading="lazy" />
              ${caption ? `<figcaption class="text-center text-[13px] text-text-soft mt-2 italic">${caption}</figcaption>` : ''}
            </figure>`;
          },
        },
        marks: {
          strong: ({ children }: any) => `<strong>${children}</strong>`,
          em: ({ children }: any) => `<em>${children}</em>`,
          link: ({ value, children }: any) =>
            `<a href="${value?.href || '#'}" target="${value?.href?.startsWith('http') ? '_blank' : '_self'}" rel="noopener noreferrer">${children}</a>`,
        },
        block: {
          h2: ({ children }: any) => `<h2>${children}</h2>`,
          h3: ({ children }: any) => `<h3>${children}</h3>`,
          blockquote: ({ children }: any) => `<blockquote>${children}</blockquote>`,
          normal: ({ children }: any) => `<p>${children}</p>`,
        },
      },
    })
  : '';
---

<BlogLayout
  title={post.title}
  description={post.excerpt}
  category={post.category}
  categoryClass={post.categoryClass || 'cat-ethical'}
  publishedAt={post.publishedAt}
  readTime={readTime}
  pullQuote={post.pullQuote}
>
  <Fragment set:html={bodyHtml} />

  <!-- Article Footer CTA -->
  <div class="mt-16 p-8 bg-cream rounded-xl text-center">
    <h3 class="font-serif text-[22px] text-navy mb-3">Enjoyed this insight?</h3>
    <p class="text-[14px] text-text-muted mb-6 max-w-[400px] mx-auto">
      Subscribe for honest thoughts on PR, storytelling, and advocacy — no spam, just substance.
    </p>
    <MagneticButton href="/insights" variant="secondary">Explore More Insights</MagneticButton>
  </div>
</BlogLayout>
