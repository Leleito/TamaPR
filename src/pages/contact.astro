---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Tama PR. Let's begin with a conversation.">

  <section class="pt-32 pb-16 bg-warm-white">
    <div class="max-w-[1200px] mx-auto px-6 md:px-16">
      <p class="text-[11px] font-semibold tracking-[2.5px] uppercase text-terracotta mb-5 reveal">Contact</p>
      <h1 class="font-serif text-[42px] lg:text-[56px] text-navy leading-[1.1] max-w-[600px] reveal">
        Let's begin with a conversation.
      </h1>
    </div>
  </section>

  <section class="py-20 bg-warm-white">
    <div class="max-w-[1200px] mx-auto px-6 md:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-16">

        <!-- Contact Form -->
        <div class="reveal">
          <h2 class="font-serif text-[24px] text-navy mb-2">We'd Love to Hear From You</h2>
          <p class="text-[14px] text-text-muted mb-2">
            Whether you're ready to explore a partnership, have a question about our work, or simply want to introduce yourself, reach out. We respond within 24 hours.
          </p>
          <p class="text-[14px] text-text-muted mb-8 italic">
            No pressure. No pitch. Just listening.
          </p>

          <form id="contact-form" class="space-y-5">
            <div>
              <label for="name" class="block text-[13px] font-medium text-navy mb-1.5">Name</label>
              <input type="text" id="name" name="name" required
                class="w-full px-4 py-3 rounded-lg border border-navy/[0.08] bg-off-white text-[14px] text-navy placeholder:text-text-soft focus:outline-none focus:border-terracotta/40 transition-colors"
                placeholder="Your name" />
            </div>
            <div>
              <label for="email" class="block text-[13px] font-medium text-navy mb-1.5">Email</label>
              <input type="email" id="email" name="email" required
                class="w-full px-4 py-3 rounded-lg border border-navy/[0.08] bg-off-white text-[14px] text-navy placeholder:text-text-soft focus:outline-none focus:border-terracotta/40 transition-colors"
                placeholder="you@example.com" />
            </div>
            <div>
              <label for="org" class="block text-[13px] font-medium text-navy mb-1.5">Organization <span class="text-text-soft">(optional)</span></label>
              <input type="text" id="org" name="organization"
                class="w-full px-4 py-3 rounded-lg border border-navy/[0.08] bg-off-white text-[14px] text-navy placeholder:text-text-soft focus:outline-none focus:border-terracotta/40 transition-colors"
                placeholder="Your organization" />
            </div>
            <div>
              <label for="message" class="block text-[13px] font-medium text-navy mb-1.5">Message</label>
              <textarea id="message" name="message" rows="5" required
                class="w-full px-4 py-3 rounded-lg border border-navy/[0.08] bg-off-white text-[14px] text-navy placeholder:text-text-soft focus:outline-none focus:border-terracotta/40 transition-colors resize-y"
                placeholder="Tell us a bit about your story and what you're hoping to explore."></textarea>
            </div>
            <button type="submit" id="submit-btn"
              class="w-full bg-terracotta text-white text-[14px] font-medium py-3.5 rounded-lg hover:bg-terracotta-hover transition-colors duration-300">
              Send Message
            </button>
          </form>
          <p id="form-status" class="text-[13px] mt-4 hidden"></p>
        </div>

        <!-- Sidebar -->
        <div class="reveal reveal-delay-2">
          <div class="space-y-10">
            <!-- Direct Contact -->
            <div>
              <h3 class="font-serif text-[20px] text-navy mb-4">Reach Us Directly</h3>
              <div class="space-y-4">
                <a href="mailto:hello@tamapr.com" class="flex items-center gap-3 text-[14px] text-text-muted no-underline hover:text-terracotta transition-colors">
                  <span class="text-terracotta">&#9993;</span> hello@tamapr.com
                </a>
              </div>
            </div>

            <!-- Find Me Elsewhere -->
            <div>
              <h3 class="font-serif text-[20px] text-navy mb-4">Find Me Elsewhere</h3>
              <div class="space-y-3">
                <a href="https://www.linkedin.com/in/tama-munira-44348214b" target="_blank" rel="noopener" class="flex items-start gap-3 text-[14px] text-text-muted no-underline hover:text-terracotta transition-colors">
                  <span class="text-terracotta mt-0.5">&#9679;</span>
                  <span><strong class="text-navy">LinkedIn</strong> &mdash; Daily thoughts on PR, storytelling, and advocacy</span>
                </a>
                <a href="https://www.instagram.com/iamtamapr" target="_blank" rel="noopener" class="flex items-start gap-3 text-[14px] text-text-muted no-underline hover:text-terracotta transition-colors">
                  <span class="text-terracotta mt-0.5">&#9679;</span>
                  <span><strong class="text-navy">Instagram</strong> &mdash; Behind the scenes, culture, and human moments</span>
                </a>
              </div>
            </div>

            <!-- Discovery Call -->
            <div class="bg-cream rounded-xl p-8">
              <h3 class="font-serif text-[20px] text-navy mb-3">Prefer to Talk?</h3>
              <p class="text-[14px] text-text-muted mb-5">
                The first step is always a conversation. Let's find a time that works for you.
              </p>
              <div class="flex flex-col gap-3">
                <a href="#" class="inline-block bg-navy text-white text-[13px] font-medium px-6 py-3 rounded-lg no-underline hover:bg-navy-deep transition-colors duration-300 text-center">
                  Schedule a Discovery Call
                </a>
                <a href="https://wa.me/254700000000" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 bg-[#25D366] text-white text-[13px] font-medium px-6 py-3 rounded-lg no-underline hover:bg-[#20BD5A] transition-colors duration-300">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.75.75 0 00.917.918l4.458-1.495A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.331 0-4.512-.654-6.378-1.788l-.446-.276-3.137 1.051 1.051-3.137-.276-.446A9.953 9.953 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/></svg>
                  WhatsApp Us
                </a>
              </div>
            </div>

            <!-- What Happens Next -->
            <div>
              <h3 class="font-serif text-[20px] text-navy mb-4">What Happens Next?</h3>
              <ol class="space-y-3 text-[14px] text-text-muted list-none">
                <li class="flex gap-3">
                  <span class="text-terracotta font-medium">1.</span>
                  We'll read your message personally (no bots, no assistants)
                </li>
                <li class="flex gap-3">
                  <span class="text-terracotta font-medium">2.</span>
                  Within 24 hours, we'll respond via email or WhatsApp
                </li>
                <li class="flex gap-3">
                  <span class="text-terracotta font-medium">3.</span>
                  We'll find a time to talk if that feels right
                </li>
                <li class="flex gap-3">
                  <span class="text-terracotta font-medium">4.</span>
                  Or we'll answer your question directly, no hard sell, ever
                </li>
              </ol>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Quote -->
  <section class="py-16 bg-cream text-center">
    <div class="max-w-[600px] mx-auto px-6 md:px-16 reveal">
      <p class="font-serif text-[20px] italic text-navy leading-relaxed">
        "Voice carries responsibility."
      </p>
      <span class="text-[13px] text-terracotta font-medium mt-3 block">&mdash; Tama PR</span>
    </div>
  </section>

</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        form.innerHTML = '<div class="text-center py-8"><p class="font-serif text-[20px] text-navy mb-2">Thank you!</p><p class="text-[14px] text-text-muted">We\'ll get back to you within 24 hours.</p></div>';
      } else {
        status.textContent = 'Something went wrong. Please try again or email directly.';
        status.className = 'text-[13px] mt-4 text-terracotta';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Message';
      }
    } catch {
      status.textContent = 'Something went wrong. Please try again or email directly.';
      status.className = 'text-[13px] mt-4 text-terracotta';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Message';
    }
  });
</script>
