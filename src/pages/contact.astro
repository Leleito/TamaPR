---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Tama PR. Let's begin with a conversation.">

  <section class="pt-32 pb-16 bg-warm-white">
    <div class="max-w-[1200px] mx-auto px-16">
      <p class="text-[11px] font-semibold tracking-[2.5px] uppercase text-terracotta mb-5 reveal">Contact</p>
      <h1 class="font-serif text-[42px] lg:text-[56px] text-navy leading-[1.1] max-w-[600px] reveal">
        Let's begin with a conversation.
      </h1>
    </div>
  </section>

  <section class="py-20 bg-warm-white">
    <div class="max-w-[1200px] mx-auto px-16">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-16">

        <!-- Contact Form -->
        <div class="reveal">
          <h2 class="font-serif text-[24px] text-navy mb-2">Send a Message</h2>
          <p class="text-[14px] text-text-muted mb-8">
            Whether you're ready to explore a partnership, have a question about my work, or simply want to introduce yourself — reach out.
          </p>

          <form id="contact-form" class="space-y-5">
            <div>
              <label for="name" class="block text-[13px] font-medium text-navy mb-1.5">Name</label>
              <input type="text" id="name" name="name" required
                class="w-full px-4 py-3 rounded-lg border border-navy/[0.08] bg-off-white text-[14px] text-navy placeholder:text-text-soft focus:outline-none focus:border-terracotta/40 transition-colors"
                placeholder="Your name" />
            </div>
            <div>
              <label for="email" class="block text-[13px] font-medium text-navy mb-1.5">Email</label>
              <input type="email" id="email" name="email" required
                class="w-full px-4 py-3 rounded-lg border border-navy/[0.08] bg-off-white text-[14px] text-navy placeholder:text-text-soft focus:outline-none focus:border-terracotta/40 transition-colors"
                placeholder="you@example.com" />
            </div>
            <div>
              <label for="org" class="block text-[13px] font-medium text-navy mb-1.5">Organization <span class="text-text-soft">(optional)</span></label>
              <input type="text" id="org" name="organization"
                class="w-full px-4 py-3 rounded-lg border border-navy/[0.08] bg-off-white text-[14px] text-navy placeholder:text-text-soft focus:outline-none focus:border-terracotta/40 transition-colors"
                placeholder="Your organization" />
            </div>
            <div>
              <label for="message" class="block text-[13px] font-medium text-navy mb-1.5">Message</label>
              <textarea id="message" name="message" rows="5" required
                class="w-full px-4 py-3 rounded-lg border border-navy/[0.08] bg-off-white text-[14px] text-navy placeholder:text-text-soft focus:outline-none focus:border-terracotta/40 transition-colors resize-y"
                placeholder="Tell me a bit about your story — and what you're hoping to explore."></textarea>
            </div>
            <button type="submit" id="submit-btn"
              class="w-full bg-terracotta text-white text-[14px] font-medium py-3.5 rounded-lg hover:bg-terracotta-hover transition-colors duration-300">
              Send Message
            </button>
          </form>
          <p id="form-status" class="text-[13px] mt-4 hidden"></p>
        </div>

        <!-- Sidebar -->
        <div class="reveal reveal-delay-2">
          <div class="space-y-10">
            <!-- Direct Contact -->
            <div>
              <h3 class="font-serif text-[20px] text-navy mb-4">Reach Me Directly</h3>
              <div class="space-y-3">
                <a href="mailto:hello@tamapr.com" class="flex items-center gap-3 text-[14px] text-text-muted no-underline hover:text-terracotta transition-colors">
                  <span class="text-terracotta">&#9993;</span> hello@tamapr.com
                </a>
                <a href="https://www.linkedin.com/in/tama-munira-44348214b" target="_blank" rel="noopener" class="flex items-center gap-3 text-[14px] text-text-muted no-underline hover:text-terracotta transition-colors">
                  <span class="text-terracotta">&#9679;</span> LinkedIn
                </a>
                <a href="https://www.instagram.com/iamtamapr" target="_blank" rel="noopener" class="flex items-center gap-3 text-[14px] text-text-muted no-underline hover:text-terracotta transition-colors">
                  <span class="text-terracotta">&#9679;</span> Instagram
                </a>
              </div>
            </div>

            <!-- Discovery Call -->
            <div class="bg-cream rounded-xl p-8">
              <h3 class="font-serif text-[20px] text-navy mb-3">Prefer to Talk?</h3>
              <p class="text-[14px] text-text-muted mb-5">
                The first step is always a conversation. Let's find a time that works for you.
              </p>
              <a href="#" class="inline-block bg-navy text-white text-[13px] font-medium px-6 py-3 rounded-lg no-underline hover:bg-navy-deep transition-colors duration-300">
                Schedule a Discovery Call
              </a>
            </div>

            <!-- What Happens Next -->
            <div>
              <h3 class="font-serif text-[20px] text-navy mb-4">What Happens Next?</h3>
              <ol class="space-y-3 text-[14px] text-text-muted list-none">
                <li class="flex gap-3">
                  <span class="text-terracotta font-medium">1.</span>
                  I'll read your message personally (no bots, no assistants)
                </li>
                <li class="flex gap-3">
                  <span class="text-terracotta font-medium">2.</span>
                  Within 24 hours, I'll respond via email or WhatsApp
                </li>
                <li class="flex gap-3">
                  <span class="text-terracotta font-medium">3.</span>
                  We'll find a time to talk if that feels right
                </li>
                <li class="flex gap-3">
                  <span class="text-terracotta font-medium">4.</span>
                  Or I'll answer your question directly — no hard sell, ever
                </li>
              </ol>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  @media (max-width: 768px) {
    section > div {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        form.innerHTML = '<div class="text-center py-8"><p class="font-serif text-[20px] text-navy mb-2">Thank you!</p><p class="text-[14px] text-text-muted">I\'ll get back to you within 24 hours.</p></div>';
      } else {
        status.textContent = 'Something went wrong. Please try again or email directly.';
        status.className = 'text-[13px] mt-4 text-terracotta';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Message';
      }
    } catch {
      status.textContent = 'Something went wrong. Please try again or email directly.';
      status.className = 'text-[13px] mt-4 text-terracotta';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Message';
    }
  });
</script>
