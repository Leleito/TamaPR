---
import BaseLayout from '../layouts/BaseLayout.astro';
import tamaPortrait from '../assets/images/tama-portrait.jpg';
import MagneticButton from '../components/MagneticButton.astro';

const philosophy = [
  {
    title: 'Honesty Over Noise',
    description: 'Advocacy begins with honesty. Communication begins with courage. The truth doesn\'t always make friends \u2014 sometimes it makes waves. We believe meaningful PR starts by saying what needs to be said, clearly and responsibly.',
  },
  {
    title: 'Sustainability with Substance',
    description: 'Sustainability isn\'t a headline \u2014 it\'s a mindset. We tell stories that align purpose with practice, building trust that lasts longer than campaigns.',
  },
  {
    title: 'Stories that Serve',
    description: 'Real PR connects meaningfully. Every message we craft considers people, communities, and long-term impact \u2014 not just visibility or metrics.',
  },
];

const pillars = [
  { number: '01', id: 'pillar-1', title: 'Personal Branding & Voice', tagline: 'The foundation where all communication begins.', subtitle: 'Because a voice that knows itself is never forgotten.', what: 'Before messaging. Before content. Before any campaign, there is voice. This pillar is dedicated to helping individuals and organizations discover, refine, and own their authentic voice. It\'s the practice of translating core identity into clear, impactful messaging that feels unmistakably yours.', why: 'Authentic brands are built by authentic voices. When a voice is rooted in identity, every message becomes unmistakable and memorable. Without this foundation, communication feels performative, inconsistent, and easily forgotten.', who: 'Founders, executives, leaders, and organizations who know their voice matters but need help clarifying it.' },
  { number: '02', id: 'pillar-2', title: 'Communication & PR Education', tagline: 'Empowering through knowledge.', subtitle: 'Because understanding how communication works is the first step to using it well.', what: 'Good communication is a skill. Powerful communication is a practice. This pillar is dedicated to demystifying PR, writing, and storytelling, offering clear, practical guidance through workshops, training, and frameworks that build lasting capability.', why: 'When people and brands understand how communication works, they express themselves more effectively, build stronger relationships, and achieve meaningful impact. Knowledge turns instinct into intention.', who: 'Teams, organizations, and leaders who want to build communication skills internally.' },
  { number: '03', id: 'pillar-3', title: 'Advocacy & Ethical Storytelling', tagline: 'The purpose that fuels our work.', subtitle: 'Because some stories need more than amplification. They need care.', what: 'This is the heart of Tama PR. We amplify underrepresented voices and sensitive narratives with dignity, ensuring stories of communities, survivors, and social justice are told with care, context, and consent.', why: 'For mission-driven organizations, ethical storytelling is not optional. It is a critical component of credibility and long-term trust. It transforms communication from extraction into partnership.', who: 'Non-profits, social enterprises, advocacy organizations, and mission-driven brands handling sensitive narratives.' },
  { number: '04', id: 'pillar-4', title: 'Corporate & Professional Communication', tagline: 'Building trust at an organizational level.', subtitle: 'Because what happens inside shapes what the world hears.', what: 'Trust isn\'t built by press releases. It\'s built by how people within an organization talk to each other, and whether the external message matches the internal reality. This pillar focuses on the systems, structures, and practices that enable clear, consistent communication within an organization.', why: 'Organizations don\'t just communicate to be seen. They communicate to be understood, trusted, and believed. But that trust starts inside. If your team doesn\'t believe your message, no external campaign will fix it.', who: 'Organizations, hospitality brands, and businesses ready to align their internal communication with their external voice.' },
  { number: '05', id: 'pillar-5', title: 'Lifestyle, Culture & Human Connection', tagline: 'The human layer of storytelling.', subtitle: 'Because all communication starts with understanding people.', what: 'A celebration of human experiences, communities, and cultural layers that shape how people connect, heal, and belong. This is where culture meets communication, and where lifestyle isn\'t just aesthetic, it\'s identity.', why: 'Good PR begins with listening to people, understanding their world, and shaping communication that resonates authentically. When brands connect with culture and community, they stop feeling like brands and start feeling like belonging.', who: 'Hospitality brands, lifestyle businesses, and cultural organizations who want their story to feel as human as the people they serve.' },
];
---

<BaseLayout title="About" description="Where powerful communication begins with truth. Learn about Tama PR.">

  <!-- Hero -->
  <section class="pt-32 pb-16 bg-warm-white">
    <div class="max-w-[1200px] mx-auto px-6 md:px-16">
      <p class="text-[11px] font-semibold tracking-[2.5px] uppercase text-terracotta mb-5 reveal">About Tama PR</p>
      <h1 class="font-serif text-[36px] md:text-[42px] lg:text-[56px] text-navy leading-[1.1] max-w-[700px] reveal">
        Where powerful communication begins with truth.
      </h1>
    </div>
  </section>

  <!-- Who We Are -->
  <section class="py-20 bg-warm-white">
    <div class="max-w-[800px] mx-auto px-6 md:px-16">
      <div class="reveal">
        <p class="text-[11px] font-semibold tracking-[2px] uppercase text-terracotta mb-5">Who We Are</p>
        <div class="space-y-5 text-[16px] leading-[1.85] text-text-muted">
          <p>
            Tama PR is built on connection, not just messaging. We believe communication carries responsibility, not just reach.
          </p>
          <p>
            We operate at the intersection of clarity, empathy, and advocacy, prioritizing understanding before visibility, and intention before performance. Every engagement begins by listening: to the people behind the brand, the values they carry, and the real-world impact their voice creates.
          </p>
          <p>
            This is not transactional PR. It is thoughtful, ethical communication designed to build trust, protect narratives, and strengthen relationships, especially where communities, livelihoods, or sensitive stories are involved.
          </p>
        </div>
      </div>

      <!-- Three-line tagline -->
      <div class="mt-10 bg-cream rounded-xl p-8 border-l-3 border-terracotta reveal">
        <div class="space-y-1 font-serif text-[18px] text-navy leading-relaxed">
          <p>Authenticity guides the work.</p>
          <p>Advocacy shapes the approach.</p>
          <p>Truth remains the goal.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- The Story Behind Tama PR -->
  <section class="py-20 bg-cream">
    <div class="max-w-[800px] mx-auto px-6 md:px-16">
      <div class="reveal">
        <p class="text-[11px] font-semibold tracking-[2px] uppercase text-terracotta mb-5">Our Origin</p>
        <h2 class="font-serif text-[28px] md:text-[32px] text-navy mb-6">The story behind Tama PR.</h2>
        <div class="space-y-5 text-[16px] leading-[1.85] text-text-muted">
          <p>
            I've always been drawn to how people speak, and what they leave unsaid.
          </p>
          <p>
            Long before PR became a profession for me, storytelling was how I made sense of the world. I listened closely. I noticed tone, pauses, intention. I paid attention to how words could soften a moment, or harden it. How they could create closeness or distance.
          </p>
          <p>
            As I moved through different spaces and industries, I began to see just how much power communication holds. I saw how stories could open doors, build trust, and give people a sense of belonging. But I also saw the other side: how easily stories could be rushed, simplified, or handled without care.
          </p>
          <p>
            Over time, what disturbed me wasn't the lack of storytelling, but the lack of responsibility around it. Visibility was often prioritized over dignity. Performance over truth. People were reduced to talking points, communities to campaigns, and lived experiences to content.
          </p>
          <p>
            That tension stayed with me.
          </p>
          <p>
            Especially in spaces involving livelihoods, in vulnerability, or identity, I felt a quiet discomfort with how easily narratives could be shaped without consent, context, or care. I began asking myself harder questions: not just what story is being told, but who is telling it, who benefits, and who carries the consequences.
          </p>
          <p>
            At some point, I realized I didn't want to just participate in communication as it was. I wanted to work differently. Slower. More intentionally. With curiosity instead of extraction. With listening before speaking.
          </p>
          <p class="font-serif text-navy text-[17px]">
            Tama PR grew from that decision.
          </p>
          <p>
            It exists because I believe voice carries responsibility. That behind every brand, every organization, every campaign, there are real people, with histories, values, and dignity, who deserve to be represented truthfully and thoughtfully.
          </p>
          <p>
            This work is personal to me. It's shaped by observation, by listening, and by choosing to honor nuance in a world that often rewards noise. I believe stories should not only be effective, but ethical. Not only compelling, but considerate.
          </p>
        </div>

        <!-- Closing statement -->
        <div class="mt-8 space-y-1 font-serif text-[17px] text-navy">
          <p>Tama PR is not about being the loudest in the room.</p>
          <p>It's about being honest.</p>
          <p>And using voice with intention.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Meet the Founder -->
  <section class="py-20 bg-warm-white">
    <div class="max-w-[1200px] mx-auto px-6 md:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-12 lg:gap-16 items-start">
        <!-- Photo -->
        <div class="flex flex-col items-center lg:items-start reveal">
          <img
            src={tamaPortrait.src}
            alt="Tama Munira Wazome"
            class="w-[220px] h-[220px] lg:w-[280px] lg:h-[280px] rounded-2xl object-cover object-top"
          />
          <div class="mt-5 text-center lg:text-left">
            <h3 class="font-serif text-[24px] text-navy">Tama Munira Wazome</h3>
            <p class="text-[14px] text-terracotta font-medium mt-1">Founder & CEO</p>
          </div>
        </div>

        <!-- Bio -->
        <div class="reveal reveal-delay-2">
          <p class="text-[11px] font-semibold tracking-[2px] uppercase text-terracotta mb-5">Meet Tama</p>
          <div class="space-y-5 text-[16px] leading-[1.85] text-text-muted">
            <p>
              A communications strategist, advocate, and storyteller committed to ethical, purpose-driven public relations. With a deep understanding of cultural narratives, media dynamics, and human-centered communication, Tama has built a practice rooted in listening, integrity, and intentional advocacy.
            </p>
          </div>

          <!-- A Note From Tama -->
          <div class="mt-8 bg-cream rounded-xl p-6 md:p-8 border-l-3 border-amber">
            <h4 class="text-[11px] font-semibold tracking-[1.5px] uppercase text-amber mb-3">A Note From Tama</h4>
            <div class="space-y-4 font-serif text-[17px] italic text-navy leading-relaxed">
              <p>
                This work is my response to a question I carried for years: What if communication could be different? Slower. More honest. Rooted in responsibility rather than reach.
              </p>
              <p>
                Every client I take on, every story I help shape, is an extension of that question. I don't have all the answers&mdash;but I show up with curiosity, care, and the belief that your voice matters.
              </p>
              <p>
                If that resonates with you, I'd love to listen.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="py-20 bg-cream">
    <div class="max-w-[1200px] mx-auto px-6 md:px-16">
      <div class="text-center mb-12 reveal">
        <p class="text-[11px] font-semibold tracking-[2px] uppercase text-terracotta mb-5">Our Philosophy</p>
        <h2 class="font-serif text-[28px] md:text-[32px] text-navy">PR should be as real as the people it represents.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {philosophy.map((item, i) => (
          <div class={`bg-warm-white border border-navy/[0.06] rounded-xl p-7 reveal reveal-delay-${i + 1}`}>
            <h3 class="font-serif text-[18px] text-navy mb-3">{item.title}</h3>
            <p class="text-[14px] leading-relaxed text-text-muted">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Lenses / Five Pillars -->
  <section class="py-20 bg-navy">
    <div class="max-w-[1200px] mx-auto px-6 md:px-16">
      <div class="text-center mb-14 reveal">
        <p class="text-[11px] font-semibold tracking-[2px] uppercase text-amber/50 mb-5">Our Lenses</p>
        <h2 class="font-serif text-[24px] md:text-[32px] text-white max-w-[600px] mx-auto">
          Tama PR stands on five pillars: the lenses through which we communicate, create, educate, and advocate.
        </h2>
      </div>
      <div class="space-y-4">
        {pillars.map((p, i) => (
          <details id={p.id} class={`group bg-white/[0.03] border border-white/[0.06] rounded-lg reveal reveal-delay-${i + 1}`}>
            <summary class="flex items-start gap-6 p-6 cursor-pointer list-none">
              <span class="text-[13px] font-semibold text-amber/50 mt-0.5">{p.number}</span>
              <div class="flex-1">
                <h3 class="font-serif text-[18px] text-white mb-1">{p.title}</h3>
                <p class="text-[14px] text-white/50 mb-0.5">{p.tagline}</p>
                <p class="text-[13px] text-white/30 italic">{p.subtitle}</p>
              </div>
              <span class="text-amber/40 text-[18px] transition-transform duration-300 group-open:rotate-45 mt-1">+</span>
            </summary>
            <div class="px-6 pb-6 pl-[3.75rem] space-y-4">
              <div>
                <h4 class="text-[12px] font-semibold tracking-[1.5px] uppercase text-amber/40 mb-2">What This Pillar Represents</h4>
                <p class="text-[14px] leading-relaxed text-white/40">{p.what}</p>
              </div>
              <div>
                <h4 class="text-[12px] font-semibold tracking-[1.5px] uppercase text-amber/40 mb-2">Why It Matters</h4>
                <p class="text-[14px] leading-relaxed text-white/40">{p.why}</p>
              </div>
              <div>
                <h4 class="text-[12px] font-semibold tracking-[1.5px] uppercase text-amber/40 mb-2">Who This Is For</h4>
                <p class="text-[14px] leading-relaxed text-white/40">{p.who}</p>
              </div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-warm-white text-center">
    <div class="max-w-[600px] mx-auto px-6 md:px-16 reveal">
      <h2 class="font-serif text-[28px] md:text-[32px] text-navy mb-4">Ready to begin?</h2>
      <p class="text-[16px] text-text-muted mb-8">No pressure. No pitch. Just listening.</p>
      <MagneticButton href="/contact" variant="primary">Schedule a Discovery Call</MagneticButton>
    </div>
  </section>

</BaseLayout>

<script>
  // Auto-open pillar details when navigating via hash (e.g. from footer links)
  function openPillarFromHash() {
    const hash = window.location.hash;
    if (hash && hash.startsWith('#pillar-')) {
      const details = document.querySelector(hash)?.closest('details') || document.querySelector(hash);
      if (details && details.tagName === 'DETAILS') {
        details.open = true;
        setTimeout(() => {
          details.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }, 100);
      }
    }
  }
  openPillarFromHash();
  window.addEventListener('hashchange', openPillarFromHash);
</script>
