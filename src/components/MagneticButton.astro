---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary';
  class?: string;
}

const { href, variant = 'primary', class: className = '' } = Astro.props;

const baseClasses = 'magnetic-btn inline-block text-[14px] font-medium px-8 py-3.5 rounded-md no-underline transition-all duration-300';
const variantClasses = variant === 'primary'
  ? 'bg-terracotta text-white hover:bg-terracotta-hover hover:-translate-y-0.5'
  : 'border border-white/20 text-white hover:bg-white/10 hover:-translate-y-0.5';
---

<a href={href} class:list={[baseClasses, variantClasses, className]} data-magnetic>
  <slot />
</a>

<script>
  document.querySelectorAll('[data-magnetic]').forEach((btn) => {
    const el = btn as HTMLElement;
    el.addEventListener('mousemove', (e) => {
      const rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      el.style.transform = `translate(${x * 0.15}px, ${y * 0.15}px)`;
    });

    el.addEventListener('mouseleave', () => {
      el.style.transform = '';
    });
  });
</script>
