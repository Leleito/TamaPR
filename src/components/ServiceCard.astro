---
interface Props {
  title: string;
  subtitle: string;
  services: string[];
  delay?: number;
}

const { title, subtitle, services, delay = 0 } = Astro.props;
---

<div class={`service-card group relative bg-warm-white border border-navy/[0.06] rounded-xl p-8 transition-all duration-500 hover:shadow-lg hover:-translate-y-1 reveal reveal-delay-${delay}`}>
  <div class="absolute left-0 top-8 bottom-8 w-[3px] bg-terracotta/0 rounded-full transition-all duration-500 group-hover:bg-terracotta"></div>
  <h3 class="font-serif text-[22px] text-navy mb-2 pl-4">{title}</h3>
  <p class="text-[13px] text-text-soft mb-5 pl-4">{subtitle}</p>
  <ul class="list-none space-y-2.5 pl-4">
    {services.map((service) => (
      <li class="text-[14px] text-text-muted leading-relaxed flex items-start gap-2">
        <span class="text-terracotta mt-1 text-[10px]">&#9679;</span>
        {service}
      </li>
    ))}
  </ul>
</div>
