---
import logoTree from '../assets/images/logo-tree.jpg';

const navLinks = [
  { label: 'About', href: '/about' },
  { label: 'Services', href: '/services' },
  { label: 'Projects', href: '/projects' },
  { label: 'How We Work', href: '/process' },
  { label: 'Insights', href: '/insights' },
  { label: 'Contact', href: '/contact' },
];

const pillars = [
  'Personal Branding & Voice',
  'Communication & PR Education',
  'Advocacy & Ethical Storytelling',
  'Corporate & Professional Communication',
  'Lifestyle, Culture & Human Connection',
];
---

<footer class="bg-[#0C1220] text-white/45">
  <div class="max-w-[1200px] mx-auto px-6 md:px-16 pt-20 pb-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[2.2fr_1fr_1fr_1fr] gap-10 lg:gap-12 pb-16 border-b border-white/[0.04]">
      <!-- Brand Column -->
      <div>
        <div class="flex items-center gap-2.5 mb-6">
          <img src={logoTree.src} alt="TamaPR" class="h-14 w-auto opacity-80 rounded-full" />
          <span class="font-serif text-xl font-semibold text-white">TamaPR</span>
        </div>
        <p class="text-[13px] leading-relaxed text-white/30 max-w-[280px]">
          Rooted in authenticity. Guided by advocacy. Ethical PR & Communications from Nairobi, Kenya.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="text-[11px] font-semibold tracking-[1.5px] uppercase text-white/[0.18] mb-6">Navigation</h4>
        <ul class="list-none space-y-3">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-[13.5px] text-white/45 no-underline hover:text-amber transition-colors duration-300">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Pillars -->
      <div>
        <h4 class="text-[11px] font-semibold tracking-[1.5px] uppercase text-white/[0.18] mb-6">Our Pillars</h4>
        <ul class="list-none space-y-3">
          {pillars.map((pillar) => (
            <li>
              <span class="text-[13.5px] text-white/45">{pillar}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h4 class="text-[11px] font-semibold tracking-[1.5px] uppercase text-white/[0.18] mb-6">Get in Touch</h4>
        <ul class="list-none space-y-3">
          <li>
            <a href="mailto:hello@tamapr.com" class="text-[13.5px] text-white/45 no-underline hover:text-amber transition-colors duration-300">
              hello@tamapr.com
            </a>
          </li>
          <li>
            <a href="https://www.linkedin.com/in/tama-munira-44348214b" target="_blank" rel="noopener" class="text-[13.5px] text-white/45 no-underline hover:text-amber transition-colors duration-300">
              LinkedIn
            </a>
          </li>
          <li>
            <a href="https://www.instagram.com/iamtamapr" target="_blank" rel="noopener" class="text-[13.5px] text-white/45 no-underline hover:text-amber transition-colors duration-300">
              Instagram
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="flex justify-between items-center pt-8 text-[11px] text-white/[0.18]">
      <span>&copy; {new Date().getFullYear()} Tama PR. All rights reserved.</span>
      <span>Nairobi, Kenya</span>
    </div>
  </div>
</footer>
