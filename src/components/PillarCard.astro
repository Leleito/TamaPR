---
interface Props {
  number: string;
  title: string;
  description: string;
  delay?: number;
}

const { number, title, description, delay = 0 } = Astro.props;
---

<div class={`pillar-card group bg-white/[0.04] border border-white/[0.06] rounded-xl p-8 cursor-pointer transition-all duration-500 hover:bg-white hover:border-navy/10 hover:shadow-lg reveal reveal-delay-${delay}`}>
  <span class="block text-[11px] font-semibold tracking-[2px] text-amber/60 mb-4 transition-colors duration-500 group-hover:text-terracotta">
    {number}
  </span>
  <h3 class="font-serif text-[20px] text-white mb-3 transition-colors duration-500 group-hover:text-navy">
    {title}
  </h3>
  <p class="text-[13.5px] leading-relaxed text-white/40 transition-colors duration-500 group-hover:text-text-muted">
    {description}
  </p>
</div>
