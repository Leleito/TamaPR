<div class="cursor-dot" id="cursor-dot"></div>
<div class="cursor-ring" id="cursor-ring"></div>

<script>
  const dot = document.getElementById('cursor-dot')!;
  const ring = document.getElementById('cursor-ring')!;

  if (window.innerWidth > 768 && window.matchMedia('(pointer: fine)').matches) {
    let mouseX = 0;
    let mouseY = 0;
    let ringX = 0;
    let ringY = 0;
    const ease = 0.15;

    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      dot.style.left = `${mouseX}px`;
      dot.style.top = `${mouseY}px`;
    });

    function animateRing() {
      ringX += (mouseX - ringX) * ease;
      ringY += (mouseY - ringY) * ease;
      ring.style.left = `${ringX}px`;
      ring.style.top = `${ringY}px`;
      requestAnimationFrame(animateRing);
    }
    animateRing();

    const hoverTargets = 'a, button, .pillar-card, .p-step, .service-card, .insight-card, .insight-featured, .case-card, [data-cursor-hover]';

    document.addEventListener('mouseover', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest(hoverTargets)) {
        document.body.classList.add('cursor-hover');
      }
    });

    document.addEventListener('mouseout', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest(hoverTargets)) {
        document.body.classList.remove('cursor-hover');
      }
    });
  } else {
    dot.style.display = 'none';
    ring.style.display = 'none';
  }
</script>
