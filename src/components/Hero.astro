---
import heroBg from '../assets/images/hero-bg.jpg';
import MagneticButton from './MagneticButton.astro';
---

<section class="hero-section relative min-h-screen flex items-center overflow-hidden">
  <!-- Parallax Background -->
  <div class="absolute inset-0 z-0" id="hero-parallax">
    <img
      src={heroBg.src}
      alt=""
      class="w-full h-[120%] object-cover object-center"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[rgba(20,31,54,0.98)] via-[rgba(20,31,54,0.85)] to-[rgba(20,31,54,0.3)]"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-[1200px] mx-auto px-6 md:px-16 w-full pt-[72px]">
    <div class="flex items-center min-h-[calc(100vh-72px)]">
      <div class="max-w-[600px]">
        <p class="text-[11px] font-semibold tracking-[2.5px] uppercase text-amber mb-6 fade-up">
          Ethical PR & Communications
        </p>
        <h1 class="font-serif text-[36px] md:text-[52px] lg:text-[64px] font-semibold leading-[1.1] text-white mb-10 split-text" id="hero-heading">
          Communication begins with truth.
        </h1>
        <div class="fade-up">
          <MagneticButton href="/contact" variant="primary">
            Start Your Story
          </MagneticButton>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 opacity-40">
    <span class="text-[10px] tracking-[2px] uppercase text-white">Scroll</span>
    <div class="w-[1px] h-8 bg-white/30 relative overflow-hidden">
      <div class="absolute top-0 w-full h-full bg-white animate-[scrollDown_1.5s_ease-in-out_infinite]"></div>
    </div>
  </div>
</section>

<style>
  @keyframes scrollDown {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100%); }
  }

  /* Mobile padding now handled by Tailwind responsive classes (px-6 md:px-16) */
  /* Mobile h1 size now handled by Tailwind (text-[32px] md:text-[52px]) */
</style>

<script>
  // Parallax effect
  const parallaxBg = document.getElementById('hero-parallax');
  if (parallaxBg) {
    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY;
      parallaxBg.style.transform = `translateY(${scrolled * 0.3}px)`;
    });
  }

  // Letter-by-letter animation (word-aware to prevent mid-word breaks)
  const heading = document.getElementById('hero-heading');
  if (heading) {
    const text = heading.textContent?.trim() || '';
    heading.innerHTML = '';
    let charIndex = 0;
    text.split(' ').forEach((word, wordIdx) => {
      if (wordIdx > 0) {
        const space = document.createElement('span');
        space.className = 'char';
        space.style.transitionDelay = `${charIndex * 0.03}s`;
        space.textContent = '\u00A0';
        heading.appendChild(space);
        charIndex++;
      }
      const wordSpan = document.createElement('span');
      wordSpan.style.display = 'inline-block';
      wordSpan.style.whiteSpace = 'nowrap';
      word.split('').forEach((char) => {
        const span = document.createElement('span');
        span.className = 'char';
        span.style.transitionDelay = `${charIndex * 0.03}s`;
        span.textContent = char;
        wordSpan.appendChild(span);
        charIndex++;
      });
      heading.appendChild(wordSpan);
    });

    setTimeout(() => {
      heading.classList.add('animate');
    }, 800);
  }

  // Fade-up elements in hero
  setTimeout(() => {
    document.querySelectorAll('.hero-section .fade-up').forEach((el) => {
      el.classList.add('visible');
    });
  }, 1200);
</script>
