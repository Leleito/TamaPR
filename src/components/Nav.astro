---
import logoTree from '../assets/images/logo-tree.jpg';

interface Props {
  isHomepage?: boolean;
}

const { isHomepage = false } = Astro.props;

const navLinks = [
  { label: 'About', href: '/about' },
  { label: 'Services', href: '/services' },
  { label: 'Projects', href: '/projects' },
  { label: 'How We Work', href: '/process' },
  { label: 'Insights', href: '/insights' },
  { label: 'Contact', href: '/contact' },
];
---

<nav class={`nav ${isHomepage ? 'hero-nav' : 'scrolled'}`} id="main-nav">
  <a href="/" class="flex items-center gap-2.5 no-underline">
    <img
      src={logoTree.src}
      alt="TamaPR"
      class="h-[38px] w-auto rounded-full"
    />
    <span class="nav-logo-text font-serif text-xl font-semibold">TamaPR</span>
  </a>

  <div class="hidden md:flex items-center gap-8">
    {navLinks.map((link) => (
      <a href={link.href} class="nav-link">{link.label}</a>
    ))}
  </div>

  <div class="hidden md:block">
    <a
      href="/contact"
      class="inline-block bg-terracotta text-white text-[13px] font-medium px-[26px] py-2.5 rounded-md hover:bg-terracotta-hover hover:-translate-y-0.5 transition-all duration-300 no-underline"
    >
      Start Your Story
    </a>
  </div>

  <button
    class="md:hidden flex flex-col justify-center gap-[5px] w-6 h-6 bg-transparent border-none cursor-pointer z-[200]"
    id="hamburger"
    aria-label="Toggle menu"
  >
    <span class="block w-full h-[2px] bg-current transition-all duration-300 origin-center" id="ham-1"></span>
    <span class="block w-full h-[2px] bg-current transition-all duration-300" id="ham-2"></span>
    <span class="block w-full h-[2px] bg-current transition-all duration-300 origin-center" id="ham-3"></span>
  </button>
</nav>

<!-- Mobile Menu -->
<div class="fixed inset-0 bg-warm-white z-[150] opacity-0 invisible pointer-events-none transition-all duration-500" id="mobile-menu">
  <div class="flex flex-col pt-[100px] px-10 pb-10 h-full">
    <div class="flex flex-col gap-0">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="font-serif text-[28px] text-navy no-underline py-5 border-b border-navy/5 transition-colors duration-300 hover:text-terracotta mobile-menu-link"
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="mt-auto pt-8">
      <a
        href="/contact"
        class="block bg-terracotta text-white text-center text-[15px] font-medium py-4 rounded-lg no-underline hover:bg-terracotta-hover transition-colors duration-300"
      >
        Start Your Story
      </a>
    </div>
  </div>
</div>

<script>
  const nav = document.getElementById('main-nav')!;
  const hamburger = document.getElementById('hamburger')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const ham1 = document.getElementById('ham-1')!;
  const ham2 = document.getElementById('ham-2')!;
  const ham3 = document.getElementById('ham-3')!;
  let menuOpen = false;

  // Scroll behavior (homepage only)
  if (nav.classList.contains('hero-nav')) {
    const hero = document.querySelector('.hero-section') as HTMLElement | null;

    window.addEventListener('scroll', () => {
      if (!hero) return;
      const threshold = hero.offsetHeight - 100;

      if (window.scrollY > threshold) {
        nav.classList.remove('hero-nav');
        nav.classList.add('scrolled');
      } else {
        nav.classList.add('hero-nav');
        nav.classList.remove('scrolled');
      }
    });
  }

  // Mobile menu toggle
  hamburger.addEventListener('click', () => {
    menuOpen = !menuOpen;

    if (menuOpen) {
      mobileMenu.style.opacity = '1';
      mobileMenu.style.visibility = 'visible';
      mobileMenu.style.pointerEvents = 'auto';
      document.body.style.overflow = 'hidden';
      ham1.style.transform = 'rotate(45deg) translate(5px, 5px)';
      ham2.style.opacity = '0';
      ham3.style.transform = 'rotate(-45deg) translate(5px, -5px)';
    } else {
      mobileMenu.style.opacity = '0';
      mobileMenu.style.visibility = 'hidden';
      mobileMenu.style.pointerEvents = 'none';
      document.body.style.overflow = '';
      ham1.style.transform = '';
      ham2.style.opacity = '';
      ham3.style.transform = '';
    }
  });

  // Close on link click
  document.querySelectorAll('.mobile-menu-link').forEach((link) => {
    link.addEventListener('click', () => {
      menuOpen = false;
      mobileMenu.style.opacity = '0';
      mobileMenu.style.visibility = 'hidden';
      mobileMenu.style.pointerEvents = 'none';
      document.body.style.overflow = '';
      ham1.style.transform = '';
      ham2.style.opacity = '';
      ham3.style.transform = '';
    });
  });
</script>
